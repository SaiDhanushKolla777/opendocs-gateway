# OpenDocs Gateway — single-GPU MI300X deployment
# Copy to .env and set values as needed.

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=3000

# vLLM endpoint (OpenAI-compatible; single endpoint)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL=
VLLM_API_KEY=

# Storage
DATABASE_URL=sqlite:///./data/opendocs.db
REDIS_URL=

# Paths
UPLOAD_DIR=./data/uploads
DATA_DIR=./data
MAX_UPLOAD_MB=50
LOG_LEVEL=INFO

# Long-context / retrieval (MI300X-aware)
MAX_RETRIEVED_CHUNKS=20
MAX_CONTEXT_CHARS=32000
MAX_ANSWER_TOKENS=1024
MAX_EXTRACTION_TOKENS=2048
MAX_COMPARE_CONTEXT_CHARS=24000
MAX_MULTI_DOCS=5
DEFAULT_LONG_CONTEXT_MODE=false
MAX_CONCURRENT_REQUESTS=4

# Hybrid RAG: dense embeddings + TF-IDF (reciprocal rank fusion by default)
RAG_ENABLED=true
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Fusion: "rrf" (recommended) or "weighted"
RAG_FUSION_MODE=rrf
RAG_SEMANTIC_WEIGHT=0.55
RAG_TFIDF_WEIGHT=0.45
RRF_K=60

# FAISS ANN index for corpus-scale semantic search
FAISS_ENABLED=true
FAISS_INDEX_DIR=./data/faiss_indexes
# Use HNSW (approximate, fast) or flat (exact, slower at scale)
FAISS_USE_HNSW=true
FAISS_HNSW_M=32
FAISS_HNSW_EF_CONSTRUCTION=64
FAISS_HNSW_EF_SEARCH=32
FAISS_NPROBE=8
